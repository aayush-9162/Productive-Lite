<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Task reminders -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Exact alarms so reminders fire on time even when the app is closed or
         the device is in Doze. USE_EXACT_ALARM is auto-granted on Android 13+
         for reminder/calendar apps; SCHEDULE_EXACT_ALARM covers Android 12. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Lets the user exempt the app from battery optimization so reminders are
         not deferred/dropped while the app is closed (OEM App Standby / Doze). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Alarm: full-screen ringing screen over the lock screen + wake lock. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Tools: QR/barcode scanner + timer vibration -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".NoteMoonApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NoteMoon">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:label="@string/app_name"
            android:theme="@style/Theme.NoteMoon">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives the exact alarm and posts the reminder notification, even
             when the app process is not running. Triggered explicitly, so it is
             not exported. -->
        <receiver
            android:name=".tasks.reminder.ReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Reschedule task reminders after a reboot. Exact alarms are cleared
             when the device restarts, so this re-arms them from the database. -->
        <receiver
            android:name=".tasks.reminder.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Full-screen alarm screen, shown (even over the lock screen) by the
             firing notification's full-screen intent. Its own task, hidden from
             recents. -->
        <activity
            android:name=".alarm.presentation.ring.AlarmRingActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity=".alarm.ring"
            android:theme="@style/Theme.NoteMoon" />

        <!-- Fires when an alarm goes off (started by setAlarmClock) and handles
             its Dismiss/Snooze actions. Triggered explicitly, so not exported. -->
        <receiver
            android:name=".alarm.receiver.AlarmReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Re-arms alarms after a reboot or app update (the OS clears them). -->
        <receiver
            android:name=".alarm.receiver.AlarmBootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Disable WorkManager's default initializer so it uses the custom
             Hilt-aware Configuration provided by NoteMoonApp. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
